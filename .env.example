# ─────────────────────────────────────────────────────────────
# NovaLeads — Environment Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/novaleads

# ── JWT / Authentication ────────────────────────────────────
JWT_SECRET=change-me-to-a-random-secret
JWT_REFRESH_SECRET=change-me-to-another-random-secret
JWT_EXPIRE_MINUTES=1440
JWT_REFRESH_EXPIRE_DAYS=7

# ── Application ─────────────────────────────────────────────
APP_NAME=NovaLeads
ADMIN_EMAIL=admin@novaleads.com
ADMIN_PASSWORD=admin123
DEBUG=true

# ── Model ────────────────────────────────────────────────────
MODEL_PATH=ml/model.pkl
PREPROCESSOR_PATH=ml/preprocessor.pkl
FEATURE_NAMES_PATH=ml/feature_names.pkl

# ── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
